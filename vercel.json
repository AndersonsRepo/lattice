{
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "docs/**", "use": "@vercel/static" },
    { "src": "api/*.ts", "use": "@vercel/node" },
    { "src": "api/*.tsx", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/docs/$1" }
  ]
}
